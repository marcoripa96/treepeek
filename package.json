{
  "name": "treepeek",
  "version": "0.1.0",
  "description": "Single-binary Rust server that exposes the current directory as a mobile-first installable PWA file browser, protected with a token URL.",
  "private": true,
  "type": "module",
  "bin": {
    "treepeek": "./treepeek"
  },
  "scripts": {
    "dev": "cargo run --manifest-path server/Cargo.toml --",
    "build": "bun run scripts/build.ts",
    "build:client": "bun run scripts/build.ts --no-compile",
    "start": "./treepeek"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.20",
    "@pierre/trees": "1.0.0-beta.3",
    "@shikijs/core": "^4.0.2",
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@tanstack/react-virtual": "^3.13.24",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "shiki": "^4.0.2",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.6.0"
  }
}
